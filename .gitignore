# This file tells Git which files to ignore.

# Ignore dependency folders
node_modules/
**/node_modules/

# Ignore all environment files (which contain secret keys)
.env
.env.*
**/.env
**/.env.*

# Ignore build output folders
dist/
build/
.next/
.vercel/

# Ignore system files
.DS_Store

# Ignore uploaded images and videos
*.mp4
*.mov
*.avi
guest-lodge-backend/public/uploads/
landing-page/0518.mp4
hotel-booking-app/0518.mp4

# Ignore temp files
.memla_patch_exec_tmp/